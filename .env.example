# Wazuh weekly report — deployment config. Copy to .env and edit.

# Wazuh manager reachable over SSH (read-only collection runs there as root via sudo).
WAZUH_HOST=wazuh.manager.local
WAZUH_SSH_USER=wazuh
WAZUH_SSH_KEY=/home/youruser/.ssh/wazuh_report

# Path to a SOCops .env providing SMTP_HOST/PORT/USER/PASS + NOTIFY_EMAIL.
SOCOPS_ENV=/home/youruser/socops/.env

# Optional: override report recipient (else falls back to NOTIFY_EMAIL above).
# REPORT_EMAIL_TO=soc@example.com

# Path on the manager to the Wazuh install-files tar (holds the indexer password).
WAZUH_INSTALL_FILES=/root/wazuh-install-files.tar
