# Wazuh weekly report — ON-MANAGER (Method B) config. Copy to .env and edit.
# Used by run_local.sh, which runs directly on the manager (no SSH).

# Label shown on the report (defaults to `hostname` if unset).
WAZUH_HOST=wazuh-manager

# Path on the manager to the install-files tar (holds the indexer password).
WAZUH_INSTALL_FILES=/root/wazuh-install-files.tar

# SMTP source: a file with SMTP_HOST/PORT/USER/PASS + NOTIFY_EMAIL.
# On the manager there is no SOCops .env, so ship a dedicated one (chmod 600).
SMTP_ENV=/opt/wazuh-weekly-report/smtp.env

# Optional: override recipient (else NOTIFY_EMAIL from SMTP_ENV).
# REPORT_EMAIL_TO=soc@example.com
